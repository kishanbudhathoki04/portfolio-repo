# ============================================================
# Next.js Frontend – Environment Variables Template
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to Git.
# ============================================================

# NestJS backend base URL (used by next.config.js rewrites)
BACKEND_URL=http://localhost:3001

# App metadata
NEXT_PUBLIC_APP_NAME=QA Portfolio
NEXT_PUBLIC_APP_AUTHOR=Your Name
