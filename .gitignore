# ============================================================
# QA Portfolio – .gitignore
# Next.js frontend + NestJS backend monorepo
# ============================================================

# ── Environment Variables ────────────────────────────────────
# Never commit secrets or local config
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production
.env.production.local
backend/.env
backend/.env.*

# ── Next.js ─────────────────────────────────────────────────
.next/
out/

# ── NestJS / Node Build Output ───────────────────────────────
backend/dist/

# ── Dependencies ─────────────────────────────────────────────
node_modules/
backend/node_modules/

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Misc ─────────────────────────────────────────────────────
*.tsbuildinfo
.turbo/
